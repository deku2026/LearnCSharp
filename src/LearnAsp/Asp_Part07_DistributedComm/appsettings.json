{
  "Distributed": {
    "Role": "Gateway",
    "CatalogHttpUrl": "http://127.0.0.1:6021/",
    "CatalogGrpcUrl": "http://127.0.0.1:6121/",
    "EnrollmentUrl": "http://127.0.0.1:6022/",
    "NoticesUrl": "http://127.0.0.1:6023/"
  },
  "ConnectionStrings": {
    "Catalog": "Host=localhost;Port=5432;Database=campus_w7_catalog;Username=dotnet;Password=dotnet_dev",
    "Enrollment": "Host=localhost;Port=5432;Database=campus_w7_enrollment;Username=dotnet;Password=dotnet_dev",
    "Messaging": "Host=localhost;Port=5432;Database=campus_w7_notices;Username=dotnet;Password=dotnet_dev",
    "RabbitMQ": "amqp://dotnet:dotnet_dev@localhost:5672/"
  },
  "GatewayAuth": {
    "Issuer": "campus-gateway",
    "Audience": "campus-capstone",
    "SigningKey": "local-development-key-change-me-32-bytes",
    "InternalToken": "local-gateway-token-change-me-32-bytes"
  },
  "RabbitMQ": {
    "RunConsumer": true,
    "RetryDelayMilliseconds": 250,
    "MaxDeliveryAttempts": 3,
    "Prefetch": 8
  },
  "Resilience": {
    "RetryAttempts": 1,
    "RetryDelayMs": 50,
    "AttemptTimeoutMs": 500,
    "TotalTimeoutMs": 2000,
    "CircuitMinimumThroughput": 2,
    "CircuitSamplingMs": 4000,
    "CircuitBreakMs": 1000
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
