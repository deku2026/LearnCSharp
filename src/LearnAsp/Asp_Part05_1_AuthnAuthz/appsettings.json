{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "Redis": "localhost:6380,abortConnect=false"
  },
  "Security": {
    "Authority": "http://localhost:8082/realms/campus-w6",
    "Audience": "campus-api",
    "WebClientId": "campus-web",
    "RequireHttpsMetadata": false,
    "RequireSecureCookies": true,
    "UseRedis": true,
    "ClockSkewSeconds": 30,
    "AllowedOrigins": [
      "http://localhost:5173"
    ],
    "ApiTokenLimit": 20,
    "ApiTokensPerPeriod": 10,
    "ApiReplenishmentSeconds": 10
  },
  "AllowedHosts": "*"
}
