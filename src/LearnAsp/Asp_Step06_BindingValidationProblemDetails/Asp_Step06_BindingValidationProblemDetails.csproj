<Project Sdk="Microsoft.NET.Sdk.Web">
  <PropertyGroup>
    <RootNamespace>Step06_BindingValidationProblemDetails</RootNamespace>
    <AssemblyName>Step06_BindingValidationProblemDetails</AssemblyName>
  </PropertyGroup>
  <PropertyGroup>
    <!-- .NET 10 built-in validation source generator: required for AddValidation() to emit interceptors.
         Without this the Minimal API validation is a silent no-op. -->
    <InterceptorsNamespaces>$(InterceptorsNamespaces);Step06_BindingValidationProblemDetails</InterceptorsNamespaces>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\Asp_Campus.Contracts\Asp_Campus.Contracts.csproj" />
    <PackageReference Include="FluentValidation.DependencyInjectionExtensions" />
  </ItemGroup>
</Project>
